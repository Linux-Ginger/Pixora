msgstr "So groß werden deine Thumbnails mit dieser Einstellung"

msgid "Toepassen"
msgstr "Anwenden"

msgid "Thumbnail-grootte wijzigen?"
msgstr "Thumbnail-Größe ändern?"

msgid "Pixora gaat alle thumbnails opnieuw genereren op {n} px. Dit kan even duren bij grote bibliotheken."
msgstr "Pixora erstellt alle Thumbnails neu mit {n} px. Bei großen Bibliotheken kann das etwas dauern."
msgid "Restart gepland (1.5s delay voor GApplication unregister)"
msgstr "Neustart geplant (1,5 s Verzögerung für GApplication-Abmeldung)"

msgid "Taal-relaunch gepland (1.5s delay, log: {p})"
msgstr "Sprach-Neustart geplant (1,5 s Verzögerung, Log: {p})"

msgid "Controleren bij import"
msgstr "Beim Import prüfen"

msgid "GitHub® en het Invertocat-logo zijn handelsmerken van GitHub, Inc."
msgstr "GitHub® und das Invertocat-Logo sind Marken von GitHub, Inc."

msgid "Backup mislukt"
msgstr "Backup fehlgeschlagen"

msgid "Kon {term} niet starten: {err}"
msgstr "{term} konnte nicht gestartet werden: {err}"

msgid "Updater-script downloaden mislukt: {err}"
msgstr "Download des Updater-Skripts fehlgeschlagen: {err}"

msgid "pixora.desktop gerepareerd: Icon={p}"
msgstr "pixora.desktop repariert: Icon={p}"

msgid "Nieuwe versie beschikbaar — klik om bij te werken"
msgstr "Neue Version verfügbar — zum Aktualisieren klicken"

msgid "Alles in Pixora staat op de USB"
msgstr "Alles in Pixora ist auf dem USB"

msgid "Backup-scan: {n} nieuw, {d} orphans (mode={m}), {b} bytes, {u} duplicaten"
msgstr "Backup-Scan: {n} neu, {d} Waisen (Modus={m}), {b} Bytes, {u} Duplikate"

msgid "Periodieke backup-scan gestart"
msgstr "Periodischer Backup-Scan gestartet"

msgid "Er staat nog {n} foto op de USB die niet meer in Pixora is. In Backup-modus blijft die bewaard als archief."
msgid_plural "Er staan nog {n} foto's op de USB die niet meer in Pixora zijn. In Backup-modus blijven ze bewaard als archief."
msgstr[0] "Es ist noch {n} Foto auf dem USB, das nicht mehr in Pixora ist. Im Backup-Modus bleibt es als Archiv erhalten."
msgstr[1] "Es sind noch {n} Fotos auf dem USB, die nicht mehr in Pixora sind. Im Backup-Modus bleiben sie als Archiv erhalten."

msgid "{n} foto op USB niet meer in Pixora (blijft bewaard)"
msgid_plural "{n} foto's op USB niet meer in Pixora (blijven bewaard)"
msgstr[0] "{n} Foto auf USB nicht mehr in Pixora (bleibt erhalten)"
msgstr[1] "{n} Fotos auf USB nicht mehr in Pixora (bleiben erhalten)"

msgid "Backup-schijf is alleen-lezen gemount. Dit gebeurt vaak met NTFS/exFAT na onveilig verwijderen op Windows.\n\nOplossing: ontkoppel de schijf in je bestandsbeheerder, sluit 'm opnieuw aan, of voer op de terminal uit:\n  sudo ntfsfix /dev/sdXN\n(vervang sdXN door je USB-device, bv. sdb1)"
msgstr "Backup-Laufwerk ist schreibgeschützt eingebunden. Das passiert oft bei NTFS/exFAT nach unsicherem Auswerfen unter Windows.\n\nLösung: Das Laufwerk im Dateimanager aushängen und wieder anschließen, oder im Terminal ausführen:\n  sudo ntfsfix /dev/sdXN\n(ersetze sdXN durch dein USB-Gerät, z. B. sdb1)"

msgid "Geen schrijfrechten op {p}: {err}"
msgstr "Keine Schreibrechte auf {p}: {err}"

msgid "Fout bij schrijven naar {p}: {err}"
msgstr "Fehler beim Schreiben nach {p}: {err}"

msgid "USB is alleen-lezen gemount. Ontkoppel 'm en sluit opnieuw aan, of voer op de terminal `sudo ntfsfix /dev/sdXN` uit."
msgstr "USB ist schreibgeschützt eingebunden. Aushängen und erneut anschließen, oder im Terminal `sudo ntfsfix /dev/sdXN` ausführen."

msgid "Backup mislukt: {err}"
msgstr "Backup fehlgeschlagen: {err}"
